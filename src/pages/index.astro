---
const journeys = [
  { number: "01", title: "The Empty Quarter", meta: "Five nights · Al Dhafra", image: "https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?auto=format&fit=crop&w=1000&q=85" },
  { number: "02", title: "Oman, After the Heat", meta: "Seven nights · Musandam to Wahiba", image: "https://images.unsplash.com/photo-1530789253388-582c481c54b0?auto=format&fit=crop&w=1000&q=85" },
  { number: "03", title: "The Saudi Season", meta: "Six nights · AlUla & Jeddah", image: "https://images.unsplash.com/photo-1548013146-72479768bada?auto=format&fit=crop&w=1000&q=85" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Terra High creates private journeys across the Middle East, from Dubai." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
    <title>Terra High — Private journeys from Dubai</title>
  </head>
  <body>
    <main>
      <section class="hero" id="top">
        <nav class="nav wrap" aria-label="Main navigation">
          <a class="wordmark" href="#top" aria-label="Terra High home">TERRA <span>HIGH</span></a>
          <div class="nav-links">
            <a href="#journeys">Journeys</a>
            <a href="#philosophy">Our approach</a>
          </div>
          <a class="nav-inquire" href="#inquire">Start a conversation <span>↗</span></a>
        </nav>

        <div class="hero-copy wrap">
          <p class="eyebrow">Private travel atelier · Dubai</p>
          <h1>There are places<br />you <em>arrive</em> at.<br />And places you enter.</h1>
          <div class="hero-bottom">
            <p>Unscripted, deeply considered journeys through the Middle East for those who travel to be changed.</p>
            <a class="round-link" href="#journeys" aria-label="Explore the collection"><span>Explore</span><i>↓</i></a>
          </div>
        </div>
        <div class="hero-credit">Wadi Rum, Jordan<br />29° 36′ N, 35° 25′ E</div>
      </section>

      <section class="intro wrap" id="philosophy">
        <p class="eyebrow dark">01 · The quiet exceptional</p>
        <div class="intro-grid">
          <h2>Beyond the itinerary,<br />a sense of <em>belonging.</em></h2>
          <div class="intro-text">
            <p>Terra High is for travelers who value the things that cannot be requested on a booking form: the right key, the first table, a storyteller who grew up beside the ruins.</p>
            <p>We make the Middle East feel personal, not packaged. Every journey begins at $100,000 and is shaped around a single question: what would make this stay with you?</p>
            <a class="text-link" href="#inquire">Discover our point of view <span>→</span></a>
          </div>
        </div>
      </section>

      <section class="statement">
        <div class="statement-image"></div>
        <div class="statement-panel">
          <p class="eyebrow">A different kind of access</p>
          <h2>The rarest luxury<br />is <em>unhurried time.</em></h2>
          <p>We design the space around an experience as carefully as the experience itself. A desert camp with nothing on the schedule. A restored house held only for you. A meal that lasts until the stories run out.</p>
          <div class="line"></div>
          <p class="small-caps">Dubai · Riyadh · Muscat · Amman</p>
        </div>
      </section>

      <section class="journeys wrap" id="journeys">
        <div class="section-head">
          <div>
            <p class="eyebrow dark">02 · A select collection</p>
            <h2>Ways to go <em>deeper.</em></h2>
          </div>
          <p>Starting points, never set paths.</p>
        </div>
        <div class="journey-list">
          {journeys.map((journey) => (
            <a class="journey" href="#inquire">
              <span class="journey-num">{journey.number}</span>
              <div class="journey-image"><img src={journey.image} alt="" loading="lazy" /></div>
              <div class="journey-info"><h3>{journey.title}</h3><p>{journey.meta}</p></div>
              <span class="journey-arrow">↗</span>
            </a>
          ))}
        </div>
      </section>

      <section class="quote-wrap wrap">
        <div class="quote-mark">“</div>
        <blockquote>They understood that luxury does not need an audience. It just needs to be felt.</blockquote>
        <p>Private client · London</p>
      </section>

      <section class="contact" id="inquire">
        <div class="contact-backdrop"></div>
        <div class="contact-content wrap">
          <p class="eyebrow">Your next chapter starts quietly</p>
          <h2>Let’s make room<br />for the <em>extraordinary.</em></h2>
          <a class="contact-link" href="mailto:hello@terrahigh.travel">hello@terrahigh.travel <span>↗</span></a>
          <div class="contact-footer">
            <p>Dubai, United Arab Emirates</p>
            <p>By appointment only</p>
          </div>
        </div>
      </section>
    </main>

    <style>
      :root { --ink: #20251f; --paper: #eee9df; --stone: #d6cfc2; --moss: #657058; --sand: #c8aa72; }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; background: var(--paper); color: var(--ink); font-family: "DM Sans", Arial, sans-serif; }
      a { color: inherit; text-decoration: none; }
      .wrap { width: min(1240px, calc(100% - 96px)); margin: 0 auto; }
      .hero { min-height: 100svh; color: #f4f0e8; position: relative; overflow: hidden; background: linear-gradient(90deg, rgba(19,26,22,.7), rgba(19,26,22,.1)), url("https://images.unsplash.com/photo-1500534623283-312aade485b7?auto=format&fit=crop&w=2200&q=90") center/cover; }
      .hero::after { content: ""; position: absolute; inset: 0; background: linear-gradient(0deg, rgba(13,20,16,.52), transparent 46%); pointer-events: none; }
      .nav { height: 104px; display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 1; border-bottom: 1px solid rgba(255,255,255,.26); font-size: 12px; letter-spacing: .03em; }
      .wordmark { font-family: "DM Mono", monospace; font-size: 16px; letter-spacing: .13em; font-weight: 500; }
      .wordmark span { font-family: "Playfair Display", serif; font-style: italic; font-weight: 400; letter-spacing: 0; }
      .nav-links { display: flex; gap: 38px; margin-left: 110px; }
      .nav-links a, .nav-inquire { opacity: .88; transition: opacity .2s; }
      .nav-links a:hover, .nav-inquire:hover { opacity: 1; }
      .nav-inquire span { font-size: 16px; padding-left: 8px; }
      .hero-copy { position: relative; z-index: 1; padding: clamp(95px, 15vh, 170px) 0 48px; min-height: calc(100svh - 104px); display: flex; flex-direction: column; justify-content: space-between; }
      .eyebrow { margin: 0; font: 11px/1.2 "DM Mono", monospace; letter-spacing: .1em; text-transform: uppercase; color: #ded7ca; }
      .eyebrow.dark { color: #697062; }
      h1, h2, h3, p { margin-top: 0; }
      h1, h2, h3, blockquote { font-family: "Playfair Display", Georgia, serif; font-weight: 400; letter-spacing: -.045em; }
      h1 { font-size: clamp(54px, 7vw, 106px); line-height: .94; max-width: 900px; margin: 38px 0 50px; }
      em { color: var(--sand); font-weight: 400; }
      .hero-bottom { display: flex; justify-content: space-between; align-items: end; gap: 32px; }
      .hero-bottom > p { width: 280px; font-size: 14px; line-height: 1.55; margin: 0; color: rgba(255,255,255,.83); }
      .round-link { height: 112px; width: 112px; display: flex; border: 1px solid rgba(255,255,255,.7); border-radius: 50%; align-items: center; justify-content: center; position: relative; font: 11px "DM Mono", monospace; text-transform: uppercase; letter-spacing: .06em; transition: background .25s, color .25s; }
      .round-link i { font-style: normal; position: absolute; bottom: 18px; font-size: 17px; }
      .round-link:hover { background: #f4f0e8; color: var(--ink); }
      .hero-credit { position: absolute; z-index: 1; right: 48px; bottom: 38px; font: 10px/1.55 "DM Mono", monospace; letter-spacing: .04em; text-align: right; color: rgba(255,255,255,.75); }
      .intro { padding: 160px 0 164px; }
      .intro-grid { display: grid; grid-template-columns: 1.3fr .7fr; gap: 12%; padding-top: 50px; }
      h2 { font-size: clamp(42px, 5.1vw, 74px); line-height: .98; margin-bottom: 0; }
      .intro h2 em, .journeys h2 em { color: var(--moss); }
      .intro-text { padding-top: 14px; }
      .intro-text p { font-size: 17px; line-height: 1.55; margin-bottom: 23px; }
      .text-link { font: 11px "DM Mono", monospace; text-transform: uppercase; letter-spacing: .07em; display: inline-block; border-bottom: 1px solid var(--ink); padding-bottom: 9px; margin-top: 15px; }
      .text-link span { padding-left: 24px; font-size: 17px; }
      .statement { min-height: 710px; display: grid; grid-template-columns: 1.08fr .92fr; background: #354033; color: #ede9df; }
      .statement-image { background: url("https://images.unsplash.com/photo-1544986581-efac024faf62?auto=format&fit=crop&w=1500&q=85") center/cover; min-height: 510px; }
      .statement-panel { padding: 110px clamp(42px, 8vw, 150px) 76px 80px; display: flex; flex-direction: column; }
      .statement-panel h2 { margin: 34px 0; font-size: clamp(43px, 4.4vw, 70px); }
      .statement-panel h2 em { color: #d7bc80; }
      .statement-panel > p:not(.eyebrow):not(.small-caps) { font-size: 16px; line-height: 1.65; color: rgba(239,236,226,.8); max-width: 380px; }
      .line { height: 1px; width: 100%; background: rgba(255,255,255,.33); margin: auto 0 26px; }
      .small-caps { font: 10px "DM Mono", monospace; letter-spacing: .1em; text-transform: uppercase; margin: 0; }
      .journeys { padding: 160px 0 138px; }
      .section-head { display: flex; align-items: end; justify-content: space-between; gap: 32px; padding-bottom: 64px; }
      .section-head h2 { margin: 37px 0 0; }
      .section-head > p { font: 11px "DM Mono", monospace; letter-spacing: .06em; text-transform: uppercase; margin-bottom: 4px; color: #62675e; }
      .journey-list { border-top: 1px solid #b8b3aa; }
      .journey { display: grid; grid-template-columns: 90px 210px 1fr 40px; align-items: center; min-height: 180px; border-bottom: 1px solid #b8b3aa; transition: background .25s, padding .25s; }
      .journey:hover { background: #e4ded2; padding-left: 18px; padding-right: 18px; }
      .journey-num { font: 11px "DM Mono", monospace; color: #6c7067; }
      .journey-image { height: 122px; overflow: hidden; }
      .journey-image img { display: block; width: 100%; height: 100%; object-fit: cover; filter: saturate(.72); transition: transform .5s; }
      .journey:hover img { transform: scale(1.06); }
      .journey-info { padding-left: 42px; }
      .journey-info h3 { font-size: 34px; margin: 0 0 8px; }
      .journey-info p { font: 11px "DM Mono", monospace; letter-spacing: .05em; text-transform: uppercase; color: #73766d; margin: 0; }
      .journey-arrow { text-align: right; font-size: 23px; }
      .quote-wrap { padding: 68px 0 165px; text-align: center; max-width: 850px; }
      .quote-mark { color: var(--sand); font: 96px/.55 "Playfair Display", serif; height: 63px; }
      blockquote { font-size: clamp(31px, 4.3vw, 57px); line-height: 1.08; margin: 0; }
      .quote-wrap p { font: 10px "DM Mono", monospace; color: #70746d; letter-spacing: .08em; text-transform: uppercase; margin: 32px 0 0; }
      .contact { position: relative; color: #f0ede3; overflow: hidden; min-height: 700px; background: #20271f; }
      .contact-backdrop { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(19,26,20,.85), rgba(19,26,20,.35)), url("https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=2200&q=85") center/cover; opacity: .72; }
      .contact-content { position: relative; min-height: 700px; padding: 106px 0 44px; display: flex; flex-direction: column; }
      .contact-content h2 { font-size: clamp(48px, 6vw, 90px); line-height: .96; margin: 37px 0 45px; }
      .contact-content h2 em { color: #d9ba7d; }
      .contact-link { align-self: flex-start; font: clamp(18px, 2vw, 26px) "DM Mono", monospace; border-bottom: 1px solid rgba(255,255,255,.7); padding-bottom: 13px; }
      .contact-link span { margin-left: 34px; }
      .contact-footer { display: flex; justify-content: space-between; margin-top: auto; font: 10px "DM Mono", monospace; text-transform: uppercase; letter-spacing: .08em; color: rgba(255,255,255,.7); }
      @media (max-width: 760px) {
        .wrap { width: min(100% - 40px, 600px); }
        .nav { height: 82px; }
        .nav-links { display: none; }
        .nav-inquire { font-size: 10px; }
        .hero-copy { min-height: calc(100svh - 82px); padding-top: 72px; }
        h1 { font-size: clamp(48px, 14vw, 76px); }
        .hero-bottom > p { width: 210px; font-size: 12px; }
        .round-link { height: 78px; width: 78px; font-size: 9px; }
        .round-link i { bottom: 9px; }
        .hero-credit { display: none; }
        .intro, .journeys { padding: 90px 0; }
        .intro-grid { grid-template-columns: 1fr; gap: 35px; padding-top: 36px; }
        .statement { grid-template-columns: 1fr; }
        .statement-image { min-height: 360px; }
        .statement-panel { min-height: 520px; padding: 67px 28px 45px; }
        .section-head { display: block; padding-bottom: 40px; }
        .section-head > p { margin-top: 22px; }
        .journey { grid-template-columns: 35px 88px 1fr 22px; min-height: 128px; }
        .journey-image { height: 82px; }
        .journey-info { padding-left: 17px; }
        .journey-info h3 { font-size: 23px; }
        .journey-info p { font-size: 8px; line-height: 1.45; }
        .quote-wrap { padding: 25px 0 90px; }
        .contact, .contact-content { min-height: 600px; }
        .contact-content { padding-top: 78px; }
      }
    </style>
  </body>
</html>
