---
const passages = [
	{
		count: "01",
		place: "The Empty Quarter",
		detail: "Six nights in the Rub' al Khali",
		image: "https://images.unsplash.com/photo-1509316785289-025f5b846b35?auto=format&fit=crop&w=1200&q=90",
	},
	{
		count: "02",
		place: "The Gulf, Unmoored",
		detail: "Four nights from Musandam to Sir Bani Yas",
		image: "https://images.unsplash.com/photo-1530789253388-582c481c54b0?auto=format&fit=crop&w=1200&q=90",
	},
	{
		count: "03",
		place: "The Kingdom at Dusk",
		detail: "Seven nights through AlUla and Jeddah",
		image: "https://images.unsplash.com/photo-1539650116574-75c0c6d73f6e?auto=format&fit=crop&w=1200&q=90",
	},
];

const principles = [
	["A private pace", "No shared departures, no rehearsed reveals. Your time is the only schedule we keep."],
	["A local line", "We work through a close circle of artists, desert families, captains, curators, and hosts."],
	["A single story", "Flights, rooms, tables, and silence are composed as one continuous experience."],
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Rāwi designs rare private journeys through the Middle East from Dubai." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:opsz,wght@14..32,400..700&display=swap" rel="stylesheet" />
		<title>Rāwi — Private travel, told differently</title>
	</head>
	<body>
		<main>
			<section class="hero" id="top">
				<div class="hero-image" aria-hidden="true"></div>
				<div class="hero-wash" aria-hidden="true"></div>
				<header class="site-header shell">
					<a class="brand" href="/" aria-label="Homepage">RĀWI<span>—</span></a>
					<nav class="desktop-nav" aria-label="Main navigation">
						<a href="#passages">Passages</a>
						<a href="#method">The Rāwi way</a>
						<a href="#contact">Contact</a>
					</nav>
					<a class="header-action" href="#contact">Begin a journey <span aria-hidden="true">↗</span></a>
					<details class="mobile-nav">
						<summary aria-label="Open navigation"><span></span><span></span></summary>
						<nav aria-label="Mobile navigation">
							<a href="#passages">Passages</a>
							<a href="#method">The Rāwi way</a>
							<a href="#contact">Begin a journey</a>
						</nav>
					</details>
				</header>

				<div class="hero-content shell">
					<p class="kicker light">Dubai · private travel studio</p>
					<h1>The Middle East,<br /><em>told by those</em><br />who know its heart.</h1>
					<div class="hero-lower">
						<p class="hero-intro">Rāwi creates deeply personal journeys for a small number of curious travellers each year. Every story begins at $100,000.</p>
						<a class="primary-link" href="#passages">Find your passage <span aria-hidden="true">↓</span></a>
					</div>
				</div>
				<p class="hero-coordinate">24° 27′ N / 54° 23′ E<br />Arabian Gulf, after midnight</p>
			</section>

			<section class="manifesto" id="method">
				<div class="shell manifesto-grid">
					<p class="kicker">A Rāwi is a keeper of stories.</p>
					<div class="manifesto-copy">
						<h2>Travel isn’t about seeing more.<br /><em>It’s about knowing where to linger.</em></h2>
						<p>We begin with the people, not the properties. A chef’s home at the edge of the old city. A long walk with the archaeologist who knows which door still opens. The right person, in the right place, before anyone asks.</p>
					</div>
				</div>
			</section>

			<section class="dial-section" aria-label="A journey in motion">
				<div class="shell dial-layout">
					<div class="dial-copy">
						<p class="kicker light">Our point of departure</p>
						<h2>Nothing<br />on the usual<br /><em>compass.</em></h2>
					</div>
					<div class="dial" aria-hidden="true">
						<div class="dial-core"><span>RA</span><i>WI</i></div>
						<div class="dial-needle"></div>
						<span class="point point-n">N</span>
						<span class="point point-e">E</span>
						<span class="point point-s">S</span>
						<span class="point point-w">W</span>
						<span class="dial-orbit orbit-one"></span>
						<span class="dial-orbit orbit-two"></span>
					</div>
					<p class="dial-note">We arrange the Middle East around the people you want to become while you are there.</p>
				</div>
			</section>

			<section class="passages" id="passages">
				<div class="shell">
					<div class="section-heading">
						<p class="kicker">Selected passages</p>
						<h2>Start somewhere<br /><em>worth getting lost.</em></h2>
						<p>Not itineraries. Invitations into the region’s most private, vital corners.</p>
					</div>
					<div class="passage-list">
						{passages.map((passage) => (
							<a class="passage" href="#contact">
								<span class="passage-number">{passage.count}</span>
								<img src={passage.image} alt="" loading="lazy" />
								<div class="passage-title"><h3>{passage.place}</h3><p>{passage.detail}</p></div>
								<span class="passage-arrow" aria-hidden="true">↗</span>
							</a>
						))}
					</div>
				</div>
			</section>

			<section class="principles">
				<div class="shell">
					<div class="principles-heading">
						<p class="kicker light">How it feels</p>
						<h2>Made to leave<br /><em>room for wonder.</em></h2>
					</div>
					<dl class="principle-list">
						{principles.map(([title, detail], index) => (
							<div class="principle">
								<dt><span>{String(index + 1).padStart(2, "0")}</span>{title}</dt>
								<dd>{detail}</dd>
							</div>
						))}
					</dl>
				</div>
			</section>

			<section class="contact" id="contact">
				<div class="shell contact-layout">
					<p class="kicker">Where do we begin?</p>
					<div class="contact-main">
						<h2>Tell us what<br />you have <em>in mind.</em></h2>
						<a class="contact-link" href="mailto:hello@rawi.travel">hello@rawi.travel <span aria-hidden="true">↗</span></a>
					</div>
					<p class="contact-note">Dubai<br />By appointment</p>
				</div>
			</section>
		</main>
		<footer class="footer">
			<div class="shell footer-row">
				<p>Rāwi Private Travel</p>
				<p>Copyright 2026</p>
				<a href="mailto:hello@rawi.travel">A story awaits</a>
			</div>
		</footer>

		<style>
			:root { --ink: #152627; --ink-soft: #254144; --paper: #f1eadc; --pearl: #fcf8ef; --red: #d95638; --sand: #d4b980; --line: rgba(21, 38, 39, .18); --display: "Cormorant Garamond", Georgia, serif; --sans: "Inter", Arial, sans-serif; }
			* { box-sizing: border-box; }
			html { scroll-behavior: smooth; }
			body { margin: 0; background: var(--paper); color: var(--ink); font-family: var(--sans); font-feature-settings: "cv02", "cv03", "cv04", "cv11", "ss01", "ss03"; -webkit-font-smoothing: antialiased; }
			a { color: inherit; text-decoration: none; }
			.shell { width: min(100% - 64px, 1320px); margin: 0 auto; }
			.hero { isolation: isolate; min-height: 100svh; position: relative; color: var(--pearl); overflow: hidden; background: var(--ink); }
			.hero-image { position: absolute; z-index: -2; inset: 0; background: url("https://images.unsplash.com/photo-1544986581-efac024faf62?auto=format&fit=crop&w=2400&q=90") center/cover; }
			.hero-wash { position: absolute; z-index: -1; inset: 0; background: linear-gradient(90deg, rgba(11,27,29,.92) 0%, rgba(11,27,29,.58) 47%, rgba(11,27,29,.2) 100%), linear-gradient(0deg, rgba(10,28,31,.75) 0%, transparent 48%); }
			.site-header { height: 100px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; border-bottom: 1px solid rgba(255,255,255,.28); }
			.brand { font-size: 20px; font-weight: 600; letter-spacing: .18em; }
			.brand span { color: var(--red); padding-left: 4px; }
			.desktop-nav { display: flex; gap: 32px; font-size: 12px; letter-spacing: .03em; }
			.desktop-nav a, .header-action { color: rgba(252,248,239,.88); }
			.header-action { justify-self: end; font-size: 12px; }
			.header-action span { color: var(--sand); padding-left: 7px; font-size: 16px; }
			.mobile-nav { display: none; justify-self: end; position: relative; }
			.mobile-nav summary { cursor: pointer; width: 44px; height: 44px; display: flex; flex-direction: column; justify-content: center; align-items: flex-end; gap: 6px; list-style: none; }
			.mobile-nav summary::-webkit-details-marker { display: none; }
			.mobile-nav summary span { width: 25px; height: 1px; background: currentColor; }
			.mobile-nav[open] summary span:last-child { width: 16px; }
			.mobile-nav nav { position: absolute; z-index: 4; top: 48px; right: 0; width: 208px; padding: 18px; display: grid; gap: 14px; background: var(--pearl); color: var(--ink); box-shadow: 0 16px 36px rgba(0,0,0,.14); }
			.hero-content { min-height: calc(100svh - 100px); display: flex; flex-direction: column; justify-content: center; padding: 84px 0 54px; }
			.kicker { margin: 0; color: var(--red); font-size: 11px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; }
			.kicker.light { color: var(--sand); }
			h1, h2, h3 { margin: 0; font-family: var(--display); font-weight: 400; letter-spacing: -.052em; text-wrap: balance; }
			h1 { max-width: 18ch; margin-top: 34px; font-size: clamp(68px, 8.7vw, 142px); line-height: .81; }
			em { color: var(--sand); font-weight: inherit; }
			.hero-lower { display: flex; align-items: end; justify-content: space-between; gap: 40px; margin-top: auto; padding-top: 60px; }
			.hero-intro { max-width: 35ch; margin: 0; font-size: 16px; line-height: 1.55; text-wrap: pretty; color: rgba(252,248,239,.8); }
			.primary-link { padding: 17px 0; border-bottom: 1px solid var(--sand); font-size: 12px; font-weight: 600; letter-spacing: .04em; }
			.primary-link span { padding-left: 36px; color: var(--sand); font-size: 18px; }
			.hero-coordinate { position: absolute; right: 32px; bottom: 31px; z-index: 1; margin: 0; text-align: right; font-size: 10px; line-height: 1.55; letter-spacing: .08em; color: rgba(252,248,239,.72); }
			.manifesto { padding: 166px 0 172px; background: var(--pearl); }
			.manifesto-grid, .contact-layout { display: grid; grid-template-columns: 5fr 7fr; gap: 72px; }
			.manifesto-copy h2, .section-heading h2, .principles h2, .contact h2 { max-width: 20ch; font-size: clamp(52px, 6.1vw, 94px); line-height: .9; }
			.manifesto-copy h2 em, .section-heading h2 em, .contact h2 em { color: var(--red); }
			.manifesto-copy > p { max-width: 41ch; margin: 41px 0 0; font-size: 18px; line-height: 1.62; text-wrap: pretty; }
			.dial-section { overflow: hidden; padding: 120px 0; background: var(--red); color: var(--pearl); }
			.dial-layout { display: grid; grid-template-columns: 4fr 5fr 3fr; gap: 72px; align-items: center; }
			.dial-copy h2 { margin-top: 27px; font-size: clamp(58px, 6.2vw, 100px); line-height: .83; }
			.dial-copy h2 em { color: var(--ink); }
			.dial { width: min(36vw, 470px); aspect-ratio: 1; justify-self: center; position: relative; border: 1px solid rgba(252,248,239,.7); border-radius: 50%; }
			.dial::before, .dial::after { content: ""; position: absolute; inset: 11%; border: 1px solid rgba(252,248,239,.32); border-radius: 50%; }
			.dial::after { inset: 29%; border-color: rgba(252,248,239,.55); }
			.dial-core { position: absolute; inset: 40%; display: grid; place-content: center; z-index: 1; border-radius: 50%; background: var(--ink); color: var(--pearl); text-align: center; font-size: 17px; letter-spacing: .09em; }
			.dial-core i { color: var(--sand); font-family: var(--display); font-size: 23px; font-weight: 500; letter-spacing: 0; }
			.dial-needle { position: absolute; left: 50%; top: 8%; width: 1px; height: 42%; transform: rotate(37deg); transform-origin: bottom; background: var(--sand); }
			.point { position: absolute; font-size: 10px; font-weight: 600; letter-spacing: .1em; }
			.point-n { top: 3%; left: 50%; transform: translateX(-50%); }.point-e { right: 4%; top: 50%; transform: translateY(-50%); }.point-s { bottom: 3%; left: 50%; transform: translateX(-50%); }.point-w { left: 4%; top: 50%; transform: translateY(-50%); }
			.dial-orbit { position: absolute; border: 1px solid rgba(21,38,39,.45); border-radius: 50%; }.orbit-one { width: 138%; height: 48%; left: -19%; top: 26%; transform: rotate(-34deg); }.orbit-two { width: 112%; height: 70%; left: -6%; top: 15%; transform: rotate(54deg); }
			.dial-note { max-width: 24ch; margin: 0; align-self: end; font-size: 16px; line-height: 1.55; text-wrap: pretty; }
			.passages { padding: 164px 0; }
			.section-heading { display: grid; grid-template-columns: 5fr 5fr 2fr; gap: 72px; align-items: end; padding-bottom: 72px; }
			.section-heading > p:last-child { max-width: 24ch; margin: 0; font-size: 14px; line-height: 1.55; text-wrap: pretty; }
			.passage-list { border-top: 1px solid var(--line); }
			.passage { min-height: 208px; display: grid; grid-template-columns: 1fr 225px 5fr auto; gap: 32px; align-items: center; border-bottom: 1px solid var(--line); }
			.passage-number { color: var(--red); font-size: 12px; font-weight: 600; letter-spacing: .08em; }
			.passage img { width: 225px; height: 146px; object-fit: cover; outline: 1px solid rgba(21,38,39,.06); outline-offset: -1px; }
			.passage-title h3 { font-size: clamp(34px, 3.5vw, 54px); line-height: .95; }
			.passage-title p { margin: 11px 0 0; color: rgba(21,38,39,.66); font-size: 12px; letter-spacing: .03em; }
			.passage-arrow { color: var(--red); font-size: 28px; }
			.passage:hover img { transform: scale(1.025); }
			.passage img { transition: transform .3s ease; }
			.principles { padding: 144px 0; color: var(--pearl); background: var(--ink); }
			.principles-heading { display: grid; grid-template-columns: 5fr 7fr; gap: 72px; }
			.principles h2 em { color: var(--sand); }
			.principle-list { margin: 116px 0 0; display: grid; grid-template-columns: repeat(3, 1fr); }
			.principle { padding: 0 44px; border-left: 1px solid rgba(252,248,239,.21); }.principle:first-child { padding-left: 0; border-left: 0; }.principle:last-child { padding-right: 0; }
			.principle dt { max-width: 16ch; font-family: var(--display); font-size: 38px; line-height: .98; letter-spacing: -.035em; }.principle dt span { display: block; margin-bottom: 23px; color: var(--sand); font-family: var(--sans); font-size: 11px; font-weight: 600; letter-spacing: .1em; }
			.principle dd { max-width: 28ch; margin: 28px 0 0; color: rgba(252,248,239,.71); font-size: 15px; line-height: 1.6; text-wrap: pretty; }
			.contact { padding: 158px 0; background: var(--sand); }
			.contact-main h2 { color: var(--ink); }
			.contact-link { display: inline-block; margin-top: 50px; padding-bottom: 12px; border-bottom: 1px solid var(--ink); font-size: clamp(18px, 2vw, 26px); font-weight: 500; }.contact-link span { padding-left: 42px; color: var(--red); }
			.contact-note { align-self: end; justify-self: end; margin: 0; text-align: right; font-size: 11px; font-weight: 600; line-height: 1.6; letter-spacing: .1em; text-transform: uppercase; }
			.footer { padding: 24px 0; background: var(--ink); color: rgba(252,248,239,.72); }.footer-row { display: flex; justify-content: space-between; gap: 24px; font-size: 11px; }.footer-row p { margin: 0; }.footer-row a { color: var(--sand); }
			@media (max-width: 800px) {
				.shell { width: min(100% - 40px, 620px); }.site-header { height: 76px; grid-template-columns: 1fr auto; }.brand { font-size: 17px; }.desktop-nav, .header-action { display: none; }.mobile-nav { display: block; }.hero-content { min-height: calc(100svh - 76px); padding: 72px 0 36px; }.hero-wash { background: linear-gradient(90deg, rgba(11,27,29,.87), rgba(11,27,29,.33)), linear-gradient(0deg, rgba(10,28,31,.8), transparent 54%); }h1 { max-width: 15ch; margin-top: 26px; font-size: clamp(58px, 15vw, 90px); }.hero-lower { align-items: start; flex-direction: column; gap: 23px; padding-top: 36px; }.hero-intro { font-size: 16px; }.hero-coordinate { display: none; }.manifesto, .passages { padding: 92px 0; }.manifesto-grid, .contact-layout, .principles-heading { grid-template-columns: 1fr; gap: 32px; }.manifesto-copy h2, .section-heading h2, .principles h2, .contact h2 { font-size: clamp(49px, 13vw, 74px); }.manifesto-copy > p { margin-top: 29px; font-size: 17px; }.dial-section { padding: 88px 0; }.dial-layout { grid-template-columns: 1fr; gap: 47px; }.dial { width: min(80vw, 410px); }.dial-note { font-size: 16px; }.section-heading { grid-template-columns: 1fr; gap: 28px; padding-bottom: 42px; }.section-heading > p:last-child { max-width: 35ch; font-size: 16px; }.passage { min-height: 150px; grid-template-columns: 28px 85px 1fr 22px; gap: 15px; }.passage img { width: 85px; height: 104px; }.passage-title h3 { font-size: 30px; }.passage-title p { margin-top: 7px; font-size: 11px; line-height: 1.4; }.passage-arrow { font-size: 21px; }.principles { padding: 92px 0; }.principle-list { grid-template-columns: 1fr; margin-top: 68px; }.principle { padding: 34px 0; border-left: 0; border-top: 1px solid rgba(252,248,239,.21); }.principle:first-child { padding-top: 0; border-top: 0; }.principle:last-child { padding-bottom: 0; }.principle dt { max-width: none; font-size: 39px; }.principle dt span { margin-bottom: 17px; }.principle dd { max-width: 37ch; margin-top: 19px; font-size: 16px; }.contact { padding: 92px 0; }.contact-layout { gap: 26px; }.contact-link { margin-top: 37px; }.contact-note { justify-self: start; text-align: left; }.footer-row { align-items: start; flex-direction: column; gap: 10px; font-size: 12px; }
			}
		</style>
	</body>
</html>
